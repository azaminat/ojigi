# Zoom Build プラットフォームの API keys
# 取得場所: zoom.us → ADMIN → Plans and Billing → Universal Credit → Build App → API keys
# ※Marketplace アプリの Client ID/Secret ではないので注意
ZOOM_API_KEY=your_api_key_here
ZOOM_API_SECRET=your_api_secret_here

# Scribe は音声を「URL」で受け取るため、ローカルファイルはS3経由で渡す
# （公開URL上の音声を直接指定する場合は不要）
S3_BUCKET=
AWS_PROFILE=default

# Slack Incoming Webhook（--slack オプション使用時のみ必要）
SLACK_WEBHOOK_URL=

# コストレシートの円換算レート
USD_JPY_RATE=150.0
